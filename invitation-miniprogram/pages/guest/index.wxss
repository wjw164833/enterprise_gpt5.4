/* 宾客展示页 - 全屏沉浸式设计 */
.page-guest {
  min-height: 100vh;
  background: #1a1a2e;
  color: #ffffff;
}

.loading-full {
  width: 100%;
  min-height: 100vh;
  background: #1a1a2e;
}

/* 英雄封面区 */
.hero-section {
  position: relative;
  width: 100%;
  height: 100vh;
  overflow: hidden;
}

.hero-bg {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
}

.hero-overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  background: linear-gradient(
    180deg,
    rgba(0, 0, 0, 0.2) 0%,
    rgba(0, 0, 0, 0.1) 40%,
    rgba(0, 0, 0, 0.5) 80%,
    rgba(0, 0, 0, 0.8) 100%
  );
}

.hero-content {
  position: absolute;
  bottom: 120rpx;
  left: 0;
  right: 0;
  padding: 0 48rpx;
  text-align: center;
}

.hero-type-badge {
  display: inline-block;
  background: rgba(255, 255, 255, 0.2);
  border: 1rpx solid rgba(255, 255, 255, 0.4);
  padding: 8rpx 32rpx;
  border-radius: var(--radius-round);
  font-size: 24rpx;
  margin-bottom: 24rpx;
  backdrop-filter: blur(10px);
}

.hero-title {
  display: block;
  font-size: 56rpx;
  font-weight: 700;
  color: #ffffff;
  text-shadow: 0 4rpx 16rpx rgba(0, 0, 0, 0.3);
  margin-bottom: 16rpx;
  line-height: 1.3;
}

.hero-date {
  display: block;
  font-size: 30rpx;
  color: rgba(255, 255, 255, 0.85);
  margin-bottom: 40rpx;
}

/* 倒计时 */
.countdown {
  display: flex;
  justify-content: center;
  align-items: center;
  gap: 8rpx;
}

.countdown-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  background: rgba(255, 255, 255, 0.15);
  border-radius: var(--radius-medium);
  padding: 16rpx 20rpx;
  min-width: 96rpx;
  backdrop-filter: blur(10px);
}

.countdown-num {
  font-size: 44rpx;
  font-weight: 700;
  color: #ffffff;
  line-height: 1;
}

.countdown-unit {
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.7);
  margin-top: 4rpx;
}

.countdown-sep {
  font-size: 36rpx;
  font-weight: 700;
  color: rgba(255, 255, 255, 0.5);
}

.countdown-expired {
  background: rgba(232, 83, 74, 0.6);
  padding: 12rpx 32rpx;
  border-radius: var(--radius-round);
  display: inline-block;
}

.countdown-expired text {
  font-size: 28rpx;
  color: #ffffff;
}

/* 内容区块 */
.section {
  padding: 0 32rpx;
  margin-top: -48rpx;
  position: relative;
  z-index: 10;
}

.section-card {
  background: #ffffff;
  border-radius: var(--radius-large);
  padding: 36rpx;
  box-shadow: var(--shadow-medium);
  color: var(--text-primary);
}

.section-title-text {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
  display: block;
}

/* 邀请语 */
.greeting-section {
  margin-top: -48rpx;
}

.greeting-deco {
  font-size: 48rpx;
  text-align: center;
  margin-bottom: 16rpx;
}

.greeting-text {
  font-size: 30rpx;
  color: var(--text-secondary);
  line-height: 2;
  text-align: center;
}

/* 活动信息 */
.info-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--divider-color);
}

.info-row:last-child {
  border-bottom: none;
}

.info-icon {
  font-size: 36rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.info-detail {
  flex: 1;
}

.info-label {
  font-size: 22rpx;
  color: var(--text-placeholder);
  display: block;
  margin-bottom: 4rpx;
}

.info-value {
  font-size: 28rpx;
  color: var(--text-primary);
  display: block;
}

.info-arrow {
  font-size: 26rpx;
  color: var(--primary-color);
  flex-shrink: 0;
}

/* 照片墙 */
.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
}

.photo-item {
  width: calc(33.33% - 6rpx);
  aspect-ratio: 1;
  border-radius: var(--radius-small);
}

/* 操作按钮 */
.action-buttons {
  display: flex;
  justify-content: center;
  gap: 24rpx;
  padding: 40rpx 32rpx;
}

.action-btn {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 28rpx 32rpx;
  border-radius: var(--radius-medium);
  min-width: 160rpx;
}

.reply-btn {
  background: linear-gradient(135deg, #E8534A, #FF7B73);
}

.bless-btn {
  background: linear-gradient(135deg, #FF9500, #FFB800);
}

.nav-btn {
  background: linear-gradient(135deg, #10AEFF, #5AC8FA);
}

.action-btn-icon {
  font-size: 36rpx;
  margin-bottom: 8rpx;
}

.action-btn-text {
  font-size: 24rpx;
  color: #ffffff;
  font-weight: 500;
}

/* 留言墙 */
.bless-section {
  margin-top: 0;
  padding-bottom: 24rpx;
}

.bless-list {
  margin-top: 8rpx;
}

/* 底部提示 */
.footer-hint {
  text-align: center;
  padding: 60rpx 32rpx 120rpx;
  background: #1a1a2e;
}

.footer-hint text {
  font-size: 28rpx;
  color: rgba(255, 255, 255, 0.5);
}

/* 弹窗通用 */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.6);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.modal-content {
  width: 100%;
  background: #ffffff;
  border-radius: var(--radius-large) var(--radius-large) 0 0;
  padding-bottom: env(safe-area-inset-bottom);
  max-height: 80vh;
  overflow-y: auto;
}

.modal-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 32rpx;
  border-bottom: 1rpx solid var(--divider-color);
}

.modal-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
}

.modal-close {
  font-size: 40rpx;
  color: var(--text-placeholder);
  line-height: 1;
  padding: 8rpx;
}

.modal-body {
  padding: 32rpx;
}

.modal-footer {
  padding: 16rpx 32rpx 32rpx;
}

/* 出席选择 */
.status-options {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.status-option {
  flex: 1;
  text-align: center;
  padding: 20rpx 0;
  border-radius: var(--radius-medium);
  background: var(--bg-secondary);
  font-size: 28rpx;
  color: var(--text-secondary);
  border: 2rpx solid transparent;
  transition: all 0.2s;
}

.status-active {
  background: #FFF0ED;
  color: var(--primary-color);
  border-color: var(--primary-color);
  font-weight: 500;
}

/* 人数控制 */
.count-control {
  display: flex;
  align-items: center;
  gap: 24rpx;
  margin-top: 12rpx;
}

.count-btn {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  background: var(--bg-secondary);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 32rpx;
  color: var(--text-primary);
}

.count-value {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--text-primary);
  min-width: 48rpx;
  text-align: center;
}
