<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.invitation.model.mapper.SubscriptionMapper">
    <select id="selectActiveByUserId" resultType="com.invitation.model.entity.Subscription">
        SELECT * FROM subscription WHERE user_id = #{userId} AND status = 1 ORDER BY created_at DESC LIMIT 1
    </select>
</mapper>
