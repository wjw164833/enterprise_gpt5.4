.page-create {
  min-height: 100vh;
  background: var(--bg-secondary);
  padding: 32rpx;
  padding-bottom: 180rpx;
}

.page-title {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.page-subtitle {
  font-size: 28rpx;
  color: var(--text-placeholder);
  margin-bottom: 40rpx;
}

.type-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.type-card {
  width: calc(50% - 10rpx);
  background: #ffffff;
  border-radius: var(--radius-medium);
  padding: 32rpx 24rpx;
  position: relative;
  border: 2rpx solid transparent;
  transition: all 0.2s;
  box-shadow: var(--shadow-light);
}

.type-selected {
  border-color: var(--primary-color);
  background: #FFF8F7;
}

.type-icon {
  width: 80rpx;
  height: 80rpx;
  border-radius: var(--radius-medium);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 36rpx;
  margin-bottom: 16rpx;
}

.type-name {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
  margin-bottom: 4rpx;
}

.type-desc {
  font-size: 22rpx;
  color: var(--text-placeholder);
  display: block;
}

.type-check {
  position: absolute;
  top: 12rpx;
  right: 12rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: var(--primary-color);
  color: #ffffff;
  font-size: 24rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  padding: 20rpx 32rpx;
  background: #ffffff;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}
