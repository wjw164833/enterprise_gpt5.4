<view class="page-list">
  <!-- Tab 切换 -->
  <view class="tab-bar">
    <view
      class="tab-item {{currentTab === index ? 'tab-item-active' : ''}}"
      wx:for="{{tabs}}"
      wx:key="key"
      data-index="{{index}}"
      bindtap="onTabChange"
    >
      {{item.name}}
    </view>
  </view>

  <!-- 骨架屏 -->
  <view wx:if="{{loading && list.length === 0}}" class="skeleton-wrapper">
    <view class="skeleton-card" wx:for="{{[1,2,3]}}" wx:key="*this">
      <view class="skeleton skeleton-image"></view>
      <view class="skeleton skeleton-title" style="width:60%"></view>
      <view class="skeleton skeleton-text" style="width:40%"></view>
    </view>
  </view>

  <!-- 列表 -->
  <view wx:elif="{{list.length > 0}}" class="list-content">
    <view
      wx:for="{{list}}"
      wx:key="id"
      data-id="{{item.id}}"
      data-status="{{item.status}}"
      bindtap="onItemTap"
    >
      <invitation-card
        item="{{item}}"
        show-action="{{true}}"
        bind:edit="onItemEdit"
        bind:share="onItemShare"
      />
    </view>

    <!-- 加载更多 -->
    <view class="load-more" wx:if="{{hasMore}}">
      <text class="load-more-text">加载中...</text>
    </view>
    <view class="load-more" wx:elif="{{list.length > 0}}">
      <text class="load-more-text">没有更多了</text>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:else class="empty-state">
    <image class="empty-state-image" src="/static/images/empty-invitation.png" mode="aspectFit" />
    <text class="empty-state-text">暂无邀请函</text>
    <button class="btn-primary empty-state-btn" bindtap="onCreateTap">创建邀请函</button>
  </view>
</view>
