<view class="page-index">
  <!-- 搜索框 -->
  <view class="search-bar">
    <image class="search-bar-icon" src="/static/icons/search.png" />
    <input
      class="search-bar-input"
      placeholder="搜索模板或邀请函"
      confirm-type="search"
      value="{{searchKey}}"
      bindinput="onSearchInput"
      bindconfirm="onSearchConfirm"
    />
  </view>

  <!-- 骨架屏 -->
  <view wx:if="{{loading}}">
    <view class="skeleton skeleton-image"></view>
    <view class="skeleton skeleton-title" style="width:50%"></view>
    <view class="skeleton skeleton-text" style="width:80%"></view>
    <view class="skeleton skeleton-text" style="width:60%"></view>
  </view>

  <!-- 正式内容 -->
  <view wx:else>
    <!-- 轮播区 -->
    <view class="banner-section" wx:if="{{bannerList.length > 0}}">
      <swiper
        class="banner-swiper"
        indicator-dots="{{true}}"
        indicator-color="rgba(255,255,255,0.5)"
        indicator-active-color="#ffffff"
        autoplay="{{true}}"
        interval="{{5000}}"
        circular="{{true}}"
        current="{{currentBanner}}"
        bindchange="onBannerChange"
      >
        <swiper-item wx:for="{{bannerList}}" wx:key="id">
          <view class="banner-item" data-id="{{item.id}}" bindtap="onBannerTap">
            <image class="banner-image" src="{{item.coverImage}}" mode="aspectFill" lazy-load />
            <view class="banner-title">{{item.name}}</view>
          </view>
        </swiper-item>
      </swiper>
    </view>

    <!-- 快捷入口 -->
    <view class="quick-entry card">
      <view class="quick-title">快速创建</view>
      <view class="quick-grid">
        <view class="quick-item" bindtap="onQuickWedding">
          <view class="quick-icon wedding-icon">💒</view>
          <text class="quick-text">婚礼</text>
        </view>
        <view class="quick-item" bindtap="onQuickBirthday">
          <view class="quick-icon birthday-icon">🎂</view>
          <text class="quick-text">生日</text>
        </view>
        <view class="quick-item" bindtap="onQuickBusiness">
          <view class="quick-icon business-icon">💼</view>
          <text class="quick-text">商务</text>
        </view>
        <view class="quick-item" bindtap="onCreateTap">
          <view class="quick-icon more-icon">✨</view>
          <text class="quick-text">更多</text>
        </view>
      </view>
    </view>

    <!-- 最近邀请函 -->
    <view class="section" wx:if="{{recentList.length > 0}}">
      <view class="section-header">
        <text class="section-title">我的邀请函</text>
        <view class="section-more" bindtap="onViewMore">
          <text>查看全部</text>
          <text class="arrow">›</text>
        </view>
      </view>
      <view class="recent-list">
        <view class="recent-item" wx:for="{{recentList}}" wx:key="id"
          data-id="{{item.id}}" bindtap="onInvitationTap">
          <view class="recent-cover">
            <image src="{{item.coverImage || '/static/images/default-cover.png'}}" mode="aspectFill" lazy-load />
          </view>
          <view class="recent-info">
            <text class="recent-title text-ellipsis">{{item.title}}</text>
            <text class="recent-type">{{item.activityTypeName}}</text>
            <view class="recent-status status-tag {{item.statusClass}}">{{item.statusText}}</view>
          </view>
        </view>
      </view>
    </view>

    <!-- 推荐模板 -->
    <view class="section" wx:if="{{hotTemplates.length > 0}}">
      <view class="section-header">
        <text class="section-title">热门模板</text>
      </view>
      <view class="template-grid">
        <view class="template-item" wx:for="{{hotTemplates}}" wx:key="id"
          data-id="{{item.id}}" bindtap="onTemplateTap">
          <view class="template-cover">
            <image src="{{item.coverImage}}" mode="aspectFill" lazy-load />
          </view>
          <text class="template-name text-ellipsis">{{item.name}}</text>
        </view>
      </view>
    </view>

    <!-- 空状态（已登录无数据） -->
    <view class="empty-state" wx:if="{{!loading && recentList.length === 0}}">
      <image class="empty-state-image" src="/static/images/empty-invitation.png" mode="aspectFit" />
      <text class="empty-state-text">还没有邀请函，快去创建一个吧</text>
      <button class="btn-primary empty-state-btn" bindtap="onCreateTap">创建邀请函</button>
    </view>
  </view>

  <!-- 浮动创建按钮 -->
  <view class="fab" bindtap="onCreateTap">
    <text class="fab-icon">+</text>
  </view>
</view>
