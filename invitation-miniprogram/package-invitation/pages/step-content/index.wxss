.page-step-content {
  min-height: 100vh;
  background: var(--bg-secondary);
  padding: 24rpx 32rpx;
  padding-bottom: 180rpx;
}

.step-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 40rpx;
}

.step-item {
  width: 48rpx; height: 48rpx; border-radius: 50%;
  background: var(--bg-secondary); border: 2rpx solid var(--border-color);
  display: flex; align-items: center; justify-content: center;
  font-size: 22rpx; color: var(--text-placeholder);
}
.step-active { background: var(--primary-color); border-color: var(--primary-color); color: #fff; }
.step-done { background: var(--success-color); border-color: var(--success-color); color: #fff; }
.step-line { flex: 1; height: 2rpx; background: var(--border-color); margin: 0 8rpx; }
.step-line-done { background: var(--success-color); }
.step-labels { display: flex; justify-content: space-between; padding: 8rpx 40rpx 24rpx; }
.step-label { font-size: 20rpx; color: var(--text-placeholder); text-align: center; flex: 1; }
.step-label-active { color: var(--primary-color); font-weight: 500; }

.content-container { margin-top: 16rpx; }

.section-card { margin-bottom: 24rpx; }
.section-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 20rpx; }
.section-title { font-size: 30rpx; font-weight: 600; color: var(--text-primary); }
.section-count { font-size: 24rpx; color: var(--text-placeholder); }

.photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-item {
  width: calc(33.33% - 12rpx);
  aspect-ratio: 1;
  border-radius: var(--radius-small);
  overflow: hidden;
  position: relative;
}

.photo-item image {
  width: 100%;
  height: 100%;
}

.photo-delete {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 28rpx;
  display: flex;
  align-items: center;
  justify-content: center;
}

.photo-add {
  width: calc(33.33% - 12rpx);
  aspect-ratio: 1;
  border-radius: var(--radius-small);
  border: 2rpx dashed var(--border-color);
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: var(--bg-grey);
}

.photo-add-icon { font-size: 48rpx; color: var(--text-placeholder); line-height: 1; }
.photo-add-text { font-size: 22rpx; color: var(--text-placeholder); margin-top: 8rpx; }

.bottom-bar {
  position: fixed; left: 0; right: 0; bottom: 0;
  display: flex; gap: 24rpx; padding: 20rpx 32rpx;
  background: #ffffff; box-shadow: 0 -2rpx 16rpx rgba(0,0,0,0.06); z-index: 100;
}
