<view class="page-guest">
  <!-- 骨架屏 -->
  <view wx:if="{{loading}}" class="loading-full">
    <view class="skeleton skeleton-image" style="height:100vh"></view>
  </view>

  <view wx:elif="{{detail}}" class="guest-content">
    <!-- 全屏封面 -->
    <view class="hero-section">
      <image class="hero-bg" src="{{detail.coverImage || '/static/images/default-cover.png'}}" mode="aspectFill" />
      <view class="hero-overlay"></view>
      <view class="hero-content animate-fadeIn">
        <view class="hero-type-badge">{{detail.activityTypeName}}</view>
        <text class="hero-title">{{detail.title}}</text>
        <text class="hero-date">{{detail.formattedDate}}</text>

        <!-- 倒计时 -->
        <view class="countdown" wx:if="{{!countdown.isExpired}}">
          <view class="countdown-item">
            <text class="countdown-num">{{countdown.days}}</text>
            <text class="countdown-unit">天</text>
          </view>
          <text class="countdown-sep">:</text>
          <view class="countdown-item">
            <text class="countdown-num">{{countdown.hours}}</text>
            <text class="countdown-unit">时</text>
          </view>
          <text class="countdown-sep">:</text>
          <view class="countdown-item">
            <text class="countdown-num">{{countdown.minutes}}</text>
            <text class="countdown-unit">分</text>
          </view>
          <text class="countdown-sep">:</text>
          <view class="countdown-item">
            <text class="countdown-num">{{countdown.seconds}}</text>
            <text class="countdown-unit">秒</text>
          </view>
        </view>
        <view class="countdown-expired" wx:else>
          <text>活动已开始</text>
        </view>
      </view>
    </view>

    <!-- 邀请语 -->
    <view class="section greeting-section" wx:if="{{detail.aiGreeting}}">
      <view class="section-card">
        <view class="greeting-deco">✉️</view>
        <text class="greeting-text">{{detail.aiGreeting}}</text>
      </view>
    </view>

    <!-- 活动信息 -->
    <view class="section info-section">
      <view class="section-card">
        <view class="info-row" wx:if="{{detail.activityDate}}">
          <text class="info-icon">📅</text>
          <view class="info-detail">
            <text class="info-label">活动时间</text>
            <text class="info-value">{{detail.formattedDate}}</text>
          </view>
        </view>
        <view class="info-row" wx:if="{{detail.activityAddress}}" bindtap="onNavigateTap">
          <text class="info-icon">📍</text>
          <view class="info-detail">
            <text class="info-label">活动地点</text>
            <text class="info-value">{{detail.activityAddress}}</text>
          </view>
          <text class="info-arrow">导航 ›</text>
        </view>
      </view>
    </view>

    <!-- 照片墙 -->
    <view class="section" wx:if="{{detail.photos && detail.photos.length > 0}}">
      <view class="section-card">
        <text class="section-title-text">照片墙</text>
        <view class="photo-grid">
          <image
            class="photo-item"
            wx:for="{{detail.photos}}"
            wx:key="id"
            src="{{item.url}}"
            mode="aspectFill"
            lazy-load
            data-urls="{{detail.photos}}"
            data-current="{{item.url}}"
            bindtap="onPhotoTap"
          />
        </view>
      </view>
    </view>

    <!-- 操作按钮区 -->
    <view class="action-buttons">
      <view class="action-btn reply-btn" bindtap="onReplyTap">
        <text class="action-btn-icon">✅</text>
        <text class="action-btn-text">出席回复</text>
      </view>
      <view class="action-btn bless-btn" bindtap="onBlessTap">
        <text class="action-btn-icon">💌</text>
        <text class="action-btn-text">送上祝福</text>
      </view>
      <view class="action-btn nav-btn" bindtap="onNavigateTap">
        <text class="action-btn-icon">🗺️</text>
        <text class="action-btn-text">导航前往</text>
      </view>
    </view>

    <!-- 留言墙 -->
    <view class="section bless-section" wx:if="{{blesses.length > 0}}">
      <view class="section-card">
        <text class="section-title-text">祝福墙</text>
        <view class="bless-list">
          <bless-card
            wx:for="{{blesses}}"
            wx:key="id"
            item="{{item}}"
          />
        </view>
      </view>
    </view>

    <!-- 底部提示 -->
    <view class="footer-hint">
      <text>期待您的到来 ❤️</text>
    </view>
  </view>

  <!-- 音乐播放器 -->
  <music-player
    wx:if="{{musicSrc}}"
    src="{{musicSrc}}"
    show="{{true}}"
    auto-play="{{true}}"
  />

  <!-- 回复弹窗 -->
  <view class="modal-mask" wx:if="{{showReplyModal}}" catchtap="onReplyClose">
    <view class="modal-content animate-slideUp" catchtap="preventTap">
      <view class="modal-header">
        <text class="modal-title">出席回复</text>
        <text class="modal-close" catchtap="onReplyClose">×</text>
      </view>

      <view class="modal-body">
        <view class="form-group">
          <text class="form-label form-label-required">姓名</text>
          <input class="form-input" placeholder="请输入您的姓名"
            value="{{replyForm.guestName}}" data-field="guestName" bindinput="onReplyInput" />
        </view>

        <view class="form-group">
          <text class="form-label">手机号</text>
          <input class="form-input" placeholder="选填" type="number"
            value="{{replyForm.guestPhone}}" data-field="guestPhone" bindinput="onReplyInput" />
        </view>

        <view class="form-group">
          <text class="form-label form-label-required">是否出席</text>
          <view class="status-options">
            <view class="status-option {{replyForm.replyStatus === 1 ? 'status-active' : ''}}"
              data-value="1" bindtap="onReplyStatusChange">出席</view>
            <view class="status-option {{replyForm.replyStatus === 2 ? 'status-active' : ''}}"
              data-value="2" bindtap="onReplyStatusChange">不确定</view>
            <view class="status-option {{replyForm.replyStatus === 3 ? 'status-active' : ''}}"
              data-value="3" bindtap="onReplyStatusChange">不出席</view>
          </view>
        </view>

        <view class="form-group" wx:if="{{replyForm.replyStatus === 1}}">
          <text class="form-label">出席人数</text>
          <view class="count-control">
            <view class="count-btn" data-type="minus" bindtap="onGuestCountChange">-</view>
            <text class="count-value">{{replyForm.guestCount}}</text>
            <view class="count-btn" data-type="plus" bindtap="onGuestCountChange">+</view>
          </view>
        </view>

        <view class="form-group">
          <text class="form-label">备注</text>
          <textarea class="form-textarea" placeholder="有什么想说的..."
            value="{{replyForm.remark}}" data-field="remark" bindinput="onReplyInput" />
        </view>
      </view>

      <view class="modal-footer">
        <button class="btn-primary btn-block" bindtap="onSubmitReply">提交回复</button>
      </view>
    </view>
  </view>

  <!-- 留言弹窗 -->
  <view class="modal-mask" wx:if="{{showBlessModal}}" catchtap="onBlessClose">
    <view class="modal-content animate-slideUp" catchtap="preventTap">
      <view class="modal-header">
        <text class="modal-title">送上祝福</text>
        <text class="modal-close" catchtap="onBlessClose">×</text>
      </view>

      <view class="modal-body">
        <view class="form-group">
          <text class="form-label form-label-required">您的姓名</text>
          <input class="form-input" placeholder="请输入您的姓名"
            value="{{blessForm.guestName}}" data-field="guestName" bindinput="onBlessInput" />
        </view>

        <view class="form-group">
          <text class="form-label form-label-required">祝福语</text>
          <textarea class="form-textarea" placeholder="写下您的祝福..."
            value="{{blessForm.content}}" data-field="content" bindinput="onBlessInput" maxlength="200" />
        </view>
      </view>

      <view class="modal-footer">
        <button class="btn-primary btn-block" bindtap="onSubmitBless">送出祝福</button>
      </view>
    </view>
  </view>
</view>
