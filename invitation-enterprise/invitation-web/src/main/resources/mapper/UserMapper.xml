<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.invitation.model.mapper.UserMapper">
    <select id="selectByPhone" resultType="com.invitation.model.entity.User">
        SELECT * FROM user WHERE phone = #{phone} AND deleted = 0 LIMIT 1
    </select>
    <select id="selectByWxOpenid" resultType="com.invitation.model.entity.User">
        SELECT * FROM user WHERE wx_openid = #{wxOpenid} AND deleted = 0 LIMIT 1
    </select>
</mapper>
