<view class="page-mine">
  <!-- 用户信息区 -->
  <view class="user-section">
    <view class="user-card card" wx:if="{{isLogin && userInfo}}">
      <view class="user-info" bindtap="onAvatarTap">
        <view class="avatar avatar-large">
          <image src="{{userInfo.avatar || '/static/images/default-avatar.png'}}" mode="aspectFill" />
        </view>
        <view class="user-detail">
          <text class="user-name">{{userInfo.nickname || '未设置昵称'}}</text>
          <text class="user-desc" wx:if="{{subscription}}">
            {{subscription.plan === 2 ? '专业版会员' : subscription.plan === 3 ? '企业版会员' : '免费版用户'}}
          </text>
        </view>
      </view>
      <view class="user-edit-hint">
        <text class="hint-text">点击修改资料 ›</text>
      </view>
    </view>

    <!-- 未登录 -->
    <view class="user-card card" wx:else>
      <view class="user-info" bindtap="onLoginTap">
        <view class="avatar avatar-large">
          <image src="/static/images/default-avatar.png" mode="aspectFill" />
        </view>
        <view class="user-detail">
          <text class="user-name">点击登录</text>
          <text class="user-desc">登录后享受更多功能</text>
        </view>
      </view>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section card">
    <view
      class="menu-item"
      wx:for="{{menuList}}"
      wx:key="key"
      data-key="{{item.key}}"
      bindtap="onMenuItemTap"
    >
      <view class="menu-left">
        <text class="menu-icon">{{item.icon}}</text>
        <text class="menu-name">{{item.name}}</text>
      </view>
      <view class="menu-right">
        <text class="menu-desc" wx:if="{{item.key === 'cache'}}">{{cacheSize}}</text>
        <text class="menu-desc" wx:elif="{{item.desc}}">{{item.desc}}</text>
        <text class="menu-arrow">›</text>
      </view>
    </view>
  </view>

  <!-- 退出登录 -->
  <view class="logout-section" wx:if="{{isLogin}}">
    <button class="btn-secondary btn-block" bindtap="onLogout">退出登录</button>
  </view>

  <!-- 版本信息 -->
  <view class="version-info">
    <text>邀请函 v1.0.0</text>
  </view>
</view>
