<view class="page-step-template">
  <!-- 步骤条 -->
  <view class="step-bar">
    <view class="step-item step-done"><text>1</text></view>
    <view class="step-line step-line-done"></view>
    <view class="step-item step-active"><text>2</text></view>
    <view class="step-line"></view>
    <view class="step-item"><text>3</text></view>
    <view class="step-line"></view>
    <view class="step-item"><text>4</text></view>
    <view class="step-line"></view>
    <view class="step-item"><text>5</text></view>
  </view>

  <view class="step-labels">
    <text class="step-label">类型</text>
    <text class="step-label step-label-active">模板</text>
    <text class="step-label">表单</text>
    <text class="step-label">内容</text>
    <text class="step-label">设置</text>
  </view>

  <!-- 模板网格 -->
  <view class="template-grid">
    <view
      class="template-card {{selectedId === item.id ? 'template-selected' : ''}}"
      wx:for="{{templateList}}"
      wx:key="id"
    >
      <view class="template-cover" data-id="{{item.id}}" bindtap="onPreviewTemplate">
        <image src="{{item.coverImage}}" mode="aspectFill" lazy-load />
        <view class="template-free" wx:if="{{item.isFree}}">免费</view>
        <view class="template-check" wx:if="{{selectedId === item.id}}">✓</view>
      </view>
      <view class="template-info" data-id="{{item.id}}" bindtap="onSelectTemplate">
        <text class="template-name text-ellipsis">{{item.name}}</text>
        <text class="template-style">{{item.style}}</text>
      </view>
    </view>
  </view>

  <!-- 空状态 -->
  <view wx:if="{{!loading && templateList.length === 0}}" class="empty-state">
    <text class="empty-state-text">暂无模板</text>
  </view>

  <!-- 预览弹窗 -->
  <view class="preview-mask" wx:if="{{showPreview}}" bindtap="onClosePreview">
    <view class="preview-container" catchtap="">
      <image class="preview-image" src="{{previewTemplate.coverImage}}" mode="widthFix" />
      <view class="preview-actions">
        <button class="btn-secondary" bindtap="onClosePreview">关闭</button>
        <button class="btn-primary" data-id="{{previewTemplate.id}}" bindtap="onSelectTemplate">使用此模板</button>
      </view>
    </view>
  </view>

  <!-- 底部操作 -->
  <view class="bottom-bar safe-bottom">
    <button class="btn-secondary" bindtap="onPrev">上一步</button>
    <button class="btn-primary" bindtap="onNext" disabled="{{!selectedId}}" style="flex:2">下一步</button>
  </view>
</view>
