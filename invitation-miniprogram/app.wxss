/**
 * 全局样式
 * WeUI 风格，统一使用 rpx 单位
 */

/* ===== 基础重置 ===== */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', Helvetica,
    'PingFang SC', 'Hiragino Sans GB', 'Microsoft YaHei', Arial, sans-serif;
  font-size: 28rpx;
  color: #333333;
  background-color: #f5f5f5;
  line-height: 1.6;
  box-sizing: border-box;
}

view, text, image, navigator {
  box-sizing: border-box;
}

/* ===== 主题色 ===== */
page {
  --primary-color: #E8534A;
  --primary-light: #FF7B73;
  --primary-dark: #C94038;
  --success-color: #07C160;
  --warning-color: #FF9500;
  --error-color: #FA5151;
  --info-color: #10AEFF;
  --text-primary: #333333;
  --text-secondary: #666666;
  --text-placeholder: #999999;
  --text-disabled: #CCCCCC;
  --bg-primary: #FFFFFF;
  --bg-secondary: #F5F5F5;
  --bg-grey: #FAFAFA;
  --border-color: #E8E8E8;
  --divider-color: #F0F0F0;
  --shadow-light: 0 2rpx 12rpx rgba(0, 0, 0, 0.04);
  --shadow-medium: 0 4rpx 24rpx rgba(0, 0, 0, 0.08);
  --radius-small: 8rpx;
  --radius-medium: 16rpx;
  --radius-large: 24rpx;
  --radius-round: 999rpx;
}

/* ===== 通用容器 ===== */
.container {
  padding: 24rpx 32rpx;
  min-height: 100vh;
  background-color: #f5f5f5;
}

.page-container {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 卡片样式 ===== */
.card {
  background: #ffffff;
  border-radius: var(--radius-medium);
  padding: 32rpx;
  margin-bottom: 24rpx;
  box-shadow: var(--shadow-light);
}

.card-hover {
  opacity: 0.9;
}

/* ===== 按钮样式 ===== */
.btn-primary {
  background: var(--primary-color);
  color: #ffffff;
  border: none;
  border-radius: var(--radius-round);
  font-size: 32rpx;
  font-weight: 500;
  padding: 0 64rpx;
  height: 88rpx;
  line-height: 88rpx;
  text-align: center;
}

.btn-primary::after {
  border: none;
}

.btn-primary-plain {
  background: transparent;
  color: var(--primary-color);
  border: 2rpx solid var(--primary-color);
  border-radius: var(--radius-round);
  font-size: 28rpx;
  padding: 0 48rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
}

.btn-primary-plain::after {
  border: none;
}

.btn-secondary {
  background: #f5f5f5;
  color: #666666;
  border: none;
  border-radius: var(--radius-round);
  font-size: 28rpx;
  padding: 0 48rpx;
  height: 72rpx;
  line-height: 72rpx;
  text-align: center;
}

.btn-secondary::after {
  border: none;
}

.btn-block {
  width: 100%;
  display: block;
}

.btn-small {
  font-size: 24rpx;
  height: 60rpx;
  line-height: 60rpx;
  padding: 0 32rpx;
}

/* ===== 文字样式 ===== */
.text-primary {
  color: var(--primary-color);
}

.text-secondary {
  color: var(--text-secondary);
}

.text-placeholder {
  color: var(--text-placeholder);
}

.text-success {
  color: var(--success-color);
}

.text-warning {
  color: var(--warning-color);
}

.text-error {
  color: var(--error-color);
}

.text-center {
  text-align: center;
}

.text-right {
  text-align: right;
}

.text-bold {
  font-weight: 600;
}

.text-ellipsis {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.text-ellipsis-2 {
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

/* ===== 布局工具 ===== */
.flex-row {
  display: flex;
  flex-direction: row;
  align-items: center;
}

.flex-column {
  display: flex;
  flex-direction: column;
}

.flex-center {
  display: flex;
  align-items: center;
  justify-content: center;
}

.flex-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.flex-wrap {
  flex-wrap: wrap;
}

.flex-1 {
  flex: 1;
}

/* ===== 间距 ===== */
.mt-8 { margin-top: 8rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-24 { margin-top: 24rpx; }
.mt-32 { margin-top: 32rpx; }
.mt-48 { margin-top: 48rpx; }
.mb-8 { margin-bottom: 8rpx; }
.mb-16 { margin-bottom: 16rpx; }
.mb-24 { margin-bottom: 24rpx; }
.mb-32 { margin-bottom: 32rpx; }
.mr-8 { margin-right: 8rpx; }
.mr-16 { margin-right: 16rpx; }
.mr-24 { margin-right: 24rpx; }
.ml-8 { margin-left: 8rpx; }
.ml-16 { margin-left: 16rpx; }
.pt-8 { padding-top: 8rpx; }
.pt-16 { padding-top: 16rpx; }
.pt-24 { padding-top: 24rpx; }
.pb-8 { padding-bottom: 8rpx; }
.pb-16 { padding-bottom: 16rpx; }
.pb-24 { padding-bottom: 24rpx; }

/* ===== 分割线 ===== */
.divider {
  height: 1rpx;
  background-color: var(--divider-color);
  margin: 24rpx 0;
}

/* ===== 状态标签 ===== */
.status-tag {
  display: inline-flex;
  align-items: center;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-small);
  font-size: 22rpx;
  font-weight: 500;
}

.status-draft {
  background: #FFF7E6;
  color: #FA8C16;
}

.status-published {
  background: #F6FFED;
  color: #52C41A;
}

.status-unpublished {
  background: #FFF1F0;
  color: #F5222D;
}

/* ===== 回复状态 ===== */
.reply-attend {
  color: var(--success-color);
}

.reply-uncertain {
  color: var(--warning-color);
}

.reply-decline {
  color: var(--error-color);
}

/* ===== 骨架屏 ===== */
.skeleton {
  background: linear-gradient(90deg, #f0f0f0 25%, #e0e0e0 50%, #f0f0f0 75%);
  background-size: 200% 100%;
  animation: skeleton-loading 1.5s infinite;
  border-radius: var(--radius-small);
}

@keyframes skeleton-loading {
  0% { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

.skeleton-text {
  height: 28rpx;
  margin-bottom: 16rpx;
  width: 60%;
}

.skeleton-title {
  height: 36rpx;
  margin-bottom: 20rpx;
  width: 40%;
}

.skeleton-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
}

.skeleton-image {
  width: 100%;
  height: 300rpx;
}

/* ===== 空状态 ===== */
.empty-state {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 120rpx 64rpx;
}

.empty-state-image {
  width: 240rpx;
  height: 240rpx;
  margin-bottom: 32rpx;
}

.empty-state-text {
  font-size: 28rpx;
  color: var(--text-placeholder);
  margin-bottom: 32rpx;
}

.empty-state-btn {
  margin-top: 16rpx;
}

/* ===== 头像 ===== */
.avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  overflow: hidden;
  background: var(--bg-secondary);
  flex-shrink: 0;
}

.avatar image {
  width: 100%;
  height: 100%;
}

.avatar-small {
  width: 56rpx;
  height: 56rpx;
}

.avatar-large {
  width: 120rpx;
  height: 120rpx;
}

/* ===== 表单 ===== */
.form-group {
  margin-bottom: 32rpx;
}

.form-label {
  font-size: 28rpx;
  color: var(--text-primary);
  font-weight: 500;
  margin-bottom: 12rpx;
}

.form-label-required::before {
  content: '*';
  color: var(--error-color);
  margin-right: 4rpx;
}

.form-input {
  background: var(--bg-secondary);
  border-radius: var(--radius-medium);
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  width: 100%;
}

.form-textarea {
  background: var(--bg-secondary);
  border-radius: var(--radius-medium);
  padding: 24rpx 28rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  width: 100%;
  min-height: 200rpx;
}

.form-hint {
  font-size: 24rpx;
  color: var(--text-placeholder);
  margin-top: 8rpx;
}

.form-error {
  font-size: 24rpx;
  color: var(--error-color);
  margin-top: 8rpx;
}

/* ===== 搜索框 ===== */
.search-bar {
  display: flex;
  align-items: center;
  background: var(--bg-secondary);
  border-radius: var(--radius-round);
  padding: 16rpx 24rpx;
  margin-bottom: 24rpx;
}

.search-bar-icon {
  width: 32rpx;
  height: 32rpx;
  margin-right: 12rpx;
  flex-shrink: 0;
}

.search-bar-input {
  flex: 1;
  font-size: 28rpx;
  color: var(--text-primary);
  height: 40rpx;
}

/* ===== Tab 切换 ===== */
.tab-bar {
  display: flex;
  background: #ffffff;
  padding: 0 32rpx;
  border-bottom: 1rpx solid var(--divider-color);
}

.tab-item {
  padding: 24rpx 32rpx;
  font-size: 28rpx;
  color: var(--text-secondary);
  position: relative;
  text-align: center;
  flex: 1;
}

.tab-item-active {
  color: var(--primary-color);
  font-weight: 600;
}

.tab-item-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 48rpx;
  height: 4rpx;
  background: var(--primary-color);
  border-radius: 2rpx;
}

/* ===== 统计卡片 ===== */
.stat-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #ffffff;
  border-radius: var(--radius-medium);
  flex: 1;
}

.stat-value {
  font-size: 40rpx;
  font-weight: 700;
  color: var(--text-primary);
}

.stat-label {
  font-size: 24rpx;
  color: var(--text-placeholder);
  margin-top: 4rpx;
}

/* ===== 底部安全区域 ===== */
.safe-bottom {
  padding-bottom: env(safe-area-inset-bottom);
}

/* ===== 浮动按钮 ===== */
.fab {
  position: fixed;
  right: 32rpx;
  bottom: 180rpx;
  width: 112rpx;
  height: 112rpx;
  border-radius: 50%;
  background: var(--primary-color);
  color: #ffffff;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 8rpx 32rpx rgba(232, 83, 74, 0.4);
  z-index: 100;
}

.fab-icon {
  font-size: 48rpx;
  line-height: 1;
}

/* ===== 动画 ===== */
@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes slideUp {
  from { transform: translateY(100rpx); opacity: 0; }
  to { transform: translateY(0); opacity: 1; }
}

@keyframes pulse {
  0%, 100% { transform: scale(1); }
  50% { transform: scale(1.05); }
}

.animate-fadeIn {
  animation: fadeIn 0.3s ease-out;
}

.animate-slideUp {
  animation: slideUp 0.4s ease-out;
}
