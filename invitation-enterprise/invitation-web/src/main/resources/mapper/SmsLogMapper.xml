<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.invitation.model.mapper.SmsLogMapper">

    <resultMap id="BaseResultMap" type="com.invitation.model.entity.SmsLog">
        <id column="id" property="id"/>
        <result column="phone" property="phone"/>
        <result column="code" property="code"/>
        <result column="template_code" property="templateCode"/>
        <result column="content" property="content"/>
        <result column="send_status" property="sendStatus"/>
        <result column="biz_id" property="bizId"/>
        <result column="error_code" property="errorCode"/>
        <result column="error_msg" property="errorMsg"/>
        <result column="ip" property="ip"/>
        <result column="created_at" property="createdAt"/>
    </resultMap>

    <select id="selectRecentByPhone" resultMap="BaseResultMap">
        SELECT * FROM sms_log
        WHERE phone = #{phone} AND send_status = 1
        ORDER BY created_at DESC
        LIMIT 1
    </select>

    <select id="countByPhoneAndTime" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM sms_log
        WHERE phone = #{phone}
          AND created_at &gt;= #{startTime}
    </select>

    <select id="countByIpAndTime" resultType="java.lang.Integer">
        SELECT COUNT(*) FROM sms_log
        WHERE ip = #{ip}
          AND created_at &gt;= #{startTime}
    </select>

</mapper>
