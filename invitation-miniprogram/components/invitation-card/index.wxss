.invitation-card {
  overflow: hidden;
  padding: 0;
  margin-bottom: 24rpx;
}

.card-cover {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.cover-image {
  width: 100%;
  height: 100%;
}

.card-type-tag {
  position: absolute;
  top: 16rpx;
  left: 16rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-small);
}

.card-status-tag {
  position: absolute;
  top: 16rpx;
  right: 16rpx;
}

.card-body {
  padding: 24rpx 28rpx;
}

.card-title {
  font-size: 32rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 16rpx;
}

.card-info {
  margin-bottom: 16rpx;
}

.info-item {
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.info-icon {
  width: 28rpx;
  height: 28rpx;
  margin-right: 8rpx;
  flex-shrink: 0;
}

.info-text {
  font-size: 24rpx;
  color: var(--text-secondary);
  flex: 1;
}

.card-stats {
  display: flex;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--divider-color);
  margin-top: 8rpx;
}

.stat-item {
  flex: 1;
  text-align: center;
}

.stat-num {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  display: block;
}

.stat-label {
  font-size: 22rpx;
  color: var(--text-placeholder);
  display: block;
  margin-top: 4rpx;
}

.card-actions {
  display: flex;
  justify-content: flex-end;
  gap: 16rpx;
  margin-top: 20rpx;
  padding-top: 16rpx;
  border-top: 1rpx solid var(--divider-color);
}

.action-btn {
  padding: 12rpx 32rpx;
  font-size: 26rpx;
  border-radius: var(--radius-round);
  background: var(--bg-secondary);
  color: var(--text-secondary);
}

.action-primary {
  background: var(--primary-color);
  color: #ffffff;
}
