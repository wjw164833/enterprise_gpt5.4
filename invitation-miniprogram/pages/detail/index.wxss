.page-detail {
  min-height: 100vh;
  background: var(--bg-secondary);
  padding-bottom: 160rpx;
}

.skeleton-wrapper {
  padding: 24rpx 32rpx;
}

/* 封面 */
.detail-cover {
  width: 100%;
  height: 420rpx;
  position: relative;
  overflow: hidden;
}

.detail-cover image {
  width: 100%;
  height: 100%;
}

.cover-overlay {
  position: absolute;
  top: 24rpx;
  right: 24rpx;
  display: flex;
  gap: 12rpx;
  align-items: center;
}

.cover-type {
  background: rgba(0, 0, 0, 0.5);
  color: #ffffff;
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: var(--radius-small);
}

/* 信息区 */
.detail-info {
  margin-top: -40rpx;
  position: relative;
  z-index: 10;
  border-radius: var(--radius-large) var(--radius-large) var(--radius-medium) var(--radius-medium);
}

.detail-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--text-primary);
  display: block;
  margin-bottom: 20rpx;
}

.detail-meta {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.meta-item {
  display: flex;
  align-items: center;
}

.meta-icon {
  font-size: 28rpx;
  margin-right: 12rpx;
}

.meta-text {
  font-size: 26rpx;
  color: var(--text-secondary);
  flex: 1;
}

/* 统计 */
.stats-section {
  padding: 0 32rpx;
  margin-bottom: 24rpx;
}

.stats-grid {
  display: flex;
  gap: 16rpx;
}

.stat-card {
  flex: 1;
  background: #ffffff;
  border-radius: var(--radius-medium);
  padding: 24rpx 16rpx;
  text-align: center;
  box-shadow: var(--shadow-light);
}

/* 邀请语 */
.greeting-text {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
}

.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 20rpx;
}

/* 快捷功能 */
.quick-actions {
  display: flex;
  justify-content: space-around;
  padding: 32rpx 16rpx;
}

.action-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.action-emoji {
  font-size: 40rpx;
  margin-bottom: 8rpx;
}

.action-name {
  font-size: 24rpx;
  color: var(--text-secondary);
}

/* 回复列表 */
.reply-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid var(--divider-color);
}

.reply-item:last-child {
  border-bottom: none;
}

.reply-header {
  display: flex;
  align-items: center;
}

.reply-user {
  flex: 1;
  margin-left: 16rpx;
}

.reply-name {
  font-size: 28rpx;
  font-weight: 500;
  color: var(--text-primary);
  display: block;
}

.reply-time {
  font-size: 22rpx;
  color: var(--text-placeholder);
  display: block;
  margin-top: 4rpx;
}

.reply-status {
  font-size: 24rpx;
  font-weight: 500;
}

.reply-info {
  margin-left: 72rpx;
  margin-top: 8rpx;
  font-size: 24rpx;
  color: var(--text-secondary);
  display: flex;
  gap: 16rpx;
}

.reply-remark {
  color: var(--text-placeholder);
}

.empty-replies {
  padding: 40rpx 0;
  text-align: center;
}

.empty-text {
  font-size: 26rpx;
  color: var(--text-placeholder);
}

.load-more {
  text-align: center;
  padding: 20rpx 0;
}

.load-more-text {
  font-size: 24rpx;
  color: var(--primary-color);
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  display: flex;
  gap: 24rpx;
  padding: 20rpx 32rpx;
  background: #ffffff;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.bottom-bar .btn-primary-plain,
.bottom-bar .btn-primary {
  flex: 1;
}

/* 操作面板 */
.action-sheet-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  display: flex;
  align-items: flex-end;
}

.action-sheet {
  width: 100%;
  background: #ffffff;
  border-radius: var(--radius-large) var(--radius-large) 0 0;
  padding: 32rpx 0 env(safe-area-inset-bottom);
}

.action-sheet-title {
  text-align: center;
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  padding: 16rpx 32rpx 24rpx;
}

.action-sheet-item {
  display: flex;
  align-items: center;
  padding: 28rpx 48rpx;
}

.action-sheet-icon {
  font-size: 32rpx;
  margin-right: 20rpx;
}

.action-sheet-name {
  font-size: 30rpx;
  color: var(--text-primary);
}

.action-sheet-cancel {
  text-align: center;
  padding: 28rpx;
  font-size: 30rpx;
  color: var(--text-placeholder);
  border-top: 8rpx solid var(--bg-secondary);
  margin-top: 16rpx;
}
