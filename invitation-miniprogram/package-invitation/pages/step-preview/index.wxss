.page-step-preview {
  min-height: 100vh;
  background: #2c2c2c;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 32rpx;
  padding-bottom: 200rpx;
}

/* 手机模拟器 */
.phone-frame {
  width: 100%;
  max-width: 500rpx;
  height: 800rpx;
  background: #000000;
  border-radius: 48rpx;
  padding: 12rpx;
  position: relative;
  box-shadow: 0 16rpx 64rpx rgba(0, 0, 0, 0.4);
}

.phone-notch {
  width: 160rpx;
  height: 24rpx;
  background: #000000;
  border-radius: 0 0 20rpx 20rpx;
  margin: 0 auto;
  position: relative;
  z-index: 10;
}

.phone-screen {
  width: 100%;
  height: calc(100% - 24rpx);
  background: #ffffff;
  border-radius: 40rpx;
  overflow: hidden;
}

.preview-content {
  padding-bottom: 40rpx;
}

/* 预览封面 */
.preview-cover {
  position: relative;
  width: 100%;
  height: 320rpx;
  overflow: hidden;
}

.preview-cover image {
  width: 100%;
  height: 100%;
}

.preview-cover-overlay {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 32rpx 24rpx;
  background: linear-gradient(transparent, rgba(0, 0, 0, 0.6));
}

.preview-type-badge {
  display: inline-block;
  background: rgba(255, 255, 255, 0.2);
  color: #ffffff;
  font-size: 18rpx;
  padding: 2rpx 12rpx;
  border-radius: 8rpx;
  margin-bottom: 8rpx;
}

.preview-title {
  display: block;
  font-size: 28rpx;
  font-weight: 700;
  color: #ffffff;
  margin-bottom: 4rpx;
}

.preview-date {
  display: block;
  font-size: 20rpx;
  color: rgba(255, 255, 255, 0.8);
}

.preview-greeting {
  padding: 24rpx;
  font-size: 22rpx;
  color: #666666;
  line-height: 1.8;
  background: #FFF8F7;
  margin: 16rpx;
  border-radius: 12rpx;
}

.preview-info {
  padding: 16rpx 24rpx;
}

.preview-info-item {
  font-size: 20rpx;
  color: #666666;
  margin-bottom: 8rpx;
}

.preview-photos {
  padding: 16rpx 24rpx;
}

.preview-section-title {
  font-size: 22rpx;
  font-weight: 600;
  color: #333333;
  margin-bottom: 12rpx;
  display: block;
}

.preview-photo-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 6rpx;
}

.preview-photo-grid image {
  width: calc(33.33% - 4rpx);
  height: 120rpx;
  border-radius: 6rpx;
}

.preview-settings {
  padding: 16rpx 24rpx;
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.preview-settings text {
  font-size: 18rpx;
  color: #999999;
}

.preview-empty {
  height: 100%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.preview-empty text {
  font-size: 28rpx;
  color: #cccccc;
}

/* 底部操作栏 */
.bottom-bar {
  position: fixed;
  left: 0; right: 0; bottom: 0;
  display: flex;
  gap: 16rpx;
  padding: 20rpx 32rpx;
  background: #ffffff;
  box-shadow: 0 -2rpx 16rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}
